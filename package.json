{
  "name": "bjelectronics-enterprise-next-supabase",
  "version": "2.1.2",
  "private": true,
  "description": "BJ ELECTRONICS enterprise ecommerce frontend for Hostinger with Supabase backend.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "postbuild": "node scripts/copy-hostinger-assets.mjs",
    "start": "npx serve@14 out -l 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preflight": "node scripts/preflight.mjs",
    "env:check": "node scripts/env-check.mjs",
    "env:check:strict": "node scripts/env-check.mjs --strict",
    "lock:check": "node scripts/lock-consistency.mjs",
    "audit:css": "node scripts/css-audit.mjs",
    "audit:dead": "node scripts/dead-import-scan.mjs",
    "audit:build": "node scripts/build-audit.mjs",
    "smoke:routes": "node scripts/route-smoke-test.mjs",
    "smoke:functional": "node scripts/functional-smoke.mjs",
    "health:report": "node scripts/build-health-report.mjs",
    "artifact:zip": "node scripts/hostinger-zip.mjs",
    "verify": "npm run preflight && npm run env:check && npm run lock:check && npm run audit:css && npm run audit:dead && npm run lint && npm run typecheck && npm run build && npm run smoke:routes && npm run smoke:functional && npm run audit:build && npm run health:report && npm run artifact:zip",
    "quality": "npm run preflight && npm run env:check && npm run lock:check && npm run audit:css && npm run audit:dead && npm run lint && npm run typecheck",
    "local:test": "npm run verify"
  },
  "dependencies": {
    "@next/env": "16.2.9",
    "@stripe/stripe-js": "^4.10.0",
    "@supabase/supabase-js": "^2.57.0",
    "lucide-react": "^0.475.0",
    "next": "16.2.9",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  }
}
